# Server Configuration
PORT=5000
NODE_ENV=development

# Database
#MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster>.mongodb.net/aidup
MONGO_URI=mongodb://localhost:27017/aidup

# Authentication
JWT_SECRET=your_super_secret_access_token_key
REFRESH_TOKEN_SECRET=your_even_more_secret_refresh_token_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Frontend Configuration
FRONTEND_URL=http://localhost:5000

# Email Service (Nodemailer - Gmail example)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password_here